{
  "name": "high-school-circuit-simulation",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build:frontend": "node scripts/build-frontend.mjs",
    "package:embed": "npm run build:frontend && node scripts/embed-packager.mjs",
    "build:edgeone": "npm run package:embed && node scripts/build-edgeone.mjs",
    "check": "npm run check:observation-contract && npm run check:interaction-mode-contract && npm run check:registry-guard && npm run check:renderer-no-legacy && npm run check:engine-no-adapters && npm run check:ci-workflow && npm run check:v2:boundaries && npm run check:v2:runtime-exclusive && npm run check:v2:coverage && npm run check:v2:runtime-safety && npm run check:maintainability && npm run check:core-size && npm run lint && npm run format:check && npm test",
    "check:full": "npm run check && npm run check:e2e && npm run baseline:p0 && npm run baseline:circuitjs && npm run baseline:ai",
    "lint": "eslint . --ext .js,.mjs,.cjs",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write \"package*.json\" \"vercel.json\" \"README.md\" \".github/**/*.yml\"",
    "format:check": "prettier --check \"package*.json\" \"vercel.json\" \"README.md\" \".github/**/*.yml\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "benchmark:p0": "node scripts/benchmark/p0-baseline.mjs",
    "baseline:p0": "node scripts/benchmark/p0-electrical-regression.mjs",
    "baseline:p0:update": "node scripts/benchmark/p0-electrical-regression.mjs --update",
    "baseline:circuitjs": "node scripts/benchmark/circuitjs-golden-regression.mjs",
    "baseline:circuitjs:update": "node scripts/benchmark/circuitjs-golden-regression.mjs --update",
    "baseline:ai": "node scripts/benchmark/ai-eval-regression.mjs",
    "baseline:ai:update": "node scripts/benchmark/ai-eval-regression.mjs --update",
    "check:docs-integrity": "node scripts/ci/assert-release-doc-integrity.mjs",
    "check:interaction-guide": "node scripts/ci/assert-interaction-guide-sync.mjs",
    "check:observation-contract": "node scripts/ci/assert-observation-runtime-contract.mjs",
    "check:interaction-mode-contract": "node scripts/ci/assert-interaction-mode-runtime-contract.mjs",
    "check:registry-guard": "node scripts/ci/assert-registry-legacy-fallback-guard.mjs",
    "check:renderer-no-legacy": "node scripts/ci/assert-no-legacy-renderer-artifacts.mjs",
    "check:engine-no-adapters": "node scripts/ci/assert-no-engine-adapter-artifacts.mjs",
    "check:ci-workflow": "node scripts/ci/assert-ci-workflow-coverage.mjs",
    "check:v2:boundaries": "node scripts/ci/assert-v2-architecture-boundaries.mjs",
    "check:v2:runtime-exclusive": "node scripts/ci/assert-v2-runtime-exclusive.mjs",
    "check:v2:coverage": "node scripts/ci/assert-v2-coverage.mjs",
    "check:v2:runtime-safety": "node scripts/ci/assert-v2-runtime-safety-dedupe.mjs",
    "check:bundle-size": "node scripts/ci/assert-bundle-size-budget.mjs",
    "check:core-size": "node scripts/ci/assert-core-file-size-budget.mjs",
    "report:debt-dashboard": "node scripts/ci/generate-debt-dashboard.mjs",
    "test:reliability": "vitest run tests/failureDiagnostics.spec.js tests/runtimeDiagnostics.spec.js tests/circuit.runtimeDiagnostics.spec.js tests/solver.commonCases.spec.js tests/wireShortCircuit.spec.js tests/solver.inputHardening.spec.js tests/solver.dynamicIntegration.spec.js",
    "test:e2e:responsive": "node scripts/e2e/responsive-touch-regression.mjs",
    "test:e2e:wire": "node scripts/e2e/wire-interaction-regression.mjs",
    "mode-conflict-matrix": "node scripts/e2e/mode-conflict-matrix.mjs",
    "test:e2e:observation": "node scripts/e2e/observation-touch-regression.mjs",
    "test:e2e:compat": "node scripts/e2e/browser-compat-smoke.mjs",
    "test:e2e:ai-mobile": "node scripts/e2e/ai-mobile-layout-regression.mjs",
    "check:e2e": "npm run test:e2e:wire && npm run test:e2e:responsive && npm run test:e2e:observation && npm run test:e2e:ai-mobile",
    "check:maintainability": "node scripts/ci/assert-maintainability-budget.mjs"
  },
  "devDependencies": {
    "esbuild": "^0.25.11",
    "eslint": "^8.57.1",
    "eslint-plugin-boundaries": "^5.4.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "rollup": "^4.59.0",
    "minimatch": "^3.1.4",
    "ajv": "^6.14.0"
  }
}
